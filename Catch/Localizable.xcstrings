    "구독은 기간이 끝나기 전 취소하지 않으면 자동 갱신됩니다. 언제든 설정 > Apple ID에서 관리할 수 있어요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscriptions auto-renew unless canceled before the period ends. Manage anytime in Settings > Apple ID."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購読は期間終了前に解約しない限り自動更新されます。設定 > Apple ID でいつでも管理できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅会在到期前未取消时自动续订。可随时在“设置 > Apple ID”中管理。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las suscripciones se renuevan automáticamente salvo que se cancelen antes de finalizar el período. Gestiónalas en Ajustes > Apple ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les abonnements se renouvellent automatiquement sauf annulation avant la fin de la période. Gérez-les dans Réglages > Apple ID."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abos verlängern sich automatisch, sofern sie nicht vor Ablauf gekündigt werden. Verwaltung in Einstellungen > Apple-ID."
          }
        }
      }
    }
  },
  "version": "1.0"
