    "친구에게 받은 6자리 코드를 입력하세요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the 6-digit code from your friend."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友達からもらった6桁のコードを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入朋友给你的6位代码。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce el código de 6 dígitos que te dio tu amigo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez le code à 6 chiffres de votre ami."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib den 6-stelligen Code von deinem Freund ein."
          }
        }
      }
    },
    "코드를 다시 확인해 주세요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please check the code again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードをもう一度確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请再次确认代码。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a comprobar el código."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez vérifier le code à nouveau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte überprüfe den Code noch einmal."
          }
        }
      }
    },
    "어느 그룹에 담을까요?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Which group should we add it to?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのグループに入れますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要放进哪个群组？"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿En qué grupo lo guardamos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans quel groupe l'ajouter ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In welche Gruppe sollen wir es legen?"
          }
        }
      }
    },
    "먼저 그룹을 만들어 주세요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please create a group first."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずグループを作ってください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先创建一个群组。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero crea un grupo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez d'abord créer un groupe."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte erstelle zuerst eine Gruppe."
          }
        }
      }
    },
    "선택한 그룹의 공유 항아리에 추가돼요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It'll be added to the selected group's shared jar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選んだグループの共有ジャーに追加されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将添加到所选群组的共享罐子里。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se añadirá al tarro compartido del grupo seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sera ajouté au bocal partagé du groupe sélectionné."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wird zum geteilten Glas der gewählten Gruppe hinzugefügt."
          }
        }
      }
    },
    "아직 담긴 스티커가 없어요 🫧": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No stickers in here yet 🫧"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだステッカーがありません 🫧"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这里还没有贴纸 🫧"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay stickers aquí 🫧"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de stickers ici 🫧"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Sticker hier 🫧"
          }
        }
      }
    },
    "스티커를 눌러 '그룹에 담기' 해보세요": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap a sticker and try 'Add to Group'"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステッカーをタップして「グループに入れる」してみましょう"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击贴纸，试试「添加到群组」吧"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un sticker y prueba 'Añadir al grupo'"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez un sticker et essayez « Ajouter au groupe »"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf einen Sticker und probiere „Zur Gruppe hinzufügen“"
          }
        }
      }
    },
