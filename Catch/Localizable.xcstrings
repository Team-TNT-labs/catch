    "프로필과 모든 수집이 영구 삭제되며 되돌릴 수 없어요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your profile and all collections will be permanently deleted and can't be undone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロフィールとすべてのコレクションが完全に削除され、元に戻せません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的资料和所有收藏将被永久删除，且无法恢复。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu perfil y todas tus colecciones se eliminarán de forma permanente y no se pueden recuperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre profil et toutes vos collections seront définitivement supprimés et irrécupérables."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Profil und alle Sammlungen werden dauerhaft gelöscht und können nicht wiederhergestellt werden."
          }
        }
      }
