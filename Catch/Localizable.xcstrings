    "그룹을 만들어 친구와 함께 스티커를 모아보세요": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a group and collect stickers with friends"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グループを作って友達と一緒にステッカーを集めましょう"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建群组，和朋友一起收集贴纸吧"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un grupo y colecciona stickers con tus amigos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un groupe et collectionnez des stickers entre amis"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle eine Gruppe und sammle Sticker mit Freunden"
          }
        }
      }
    },
    "아직 그룹이 없어요": {
      "localizations": {
